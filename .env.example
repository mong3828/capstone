# JWT (지갑 로그인 후 액세스·리프레시 토큰)
B2MARK_JWT_SECRET=change-me-to-a-long-random-string

# SQLite 기본: 프로젝트 data/b2mark.sqlite (선택)
# B2MARK_DATABASE_URL=sqlite:///C:/path/to/b2mark.sqlite

# POST /watermark 기본 비밀키 (폼에 secret_key 없을 때)
# B2MARK_WATERMARK_SECRET_KEY=

# 토큰 만료 (선택)
# B2MARK_JWT_ACCESS_MINUTES=15
# B2MARK_JWT_REFRESH_DAYS=30
