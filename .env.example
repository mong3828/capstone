# JWT (지갑 로그인 후 액세스·리프레시 토큰)
MINTMARK_JWT_SECRET=change-me-to-a-long-random-string

# SQLite 기본: 프로젝트 data/mintmark.sqlite (이 변수 없을 때)
# MINTMARK_DATABASE_URL=sqlite:///C:/path/to/mintmark.sqlite

# AWS RDS PostgreSQL 예시 (비밀번호에 특수문자 있으면 URL 인코딩 필요)
# MINTMARK_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@your-db.xxxx.ap-northeast-2.rds.amazonaws.com:5432/mintmark?sslmode=require

# POST /watermark 기본 비밀키 (폼에 secret_key 없을 때)
# MINTMARK_WATERMARK_SECRET_KEY=

# 토큰 만료 (선택)
# MINTMARK_JWT_ACCESS_MINUTES=15
# MINTMARK_JWT_REFRESH_DAYS=30
