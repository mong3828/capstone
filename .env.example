# B2MARK 환경 변수 설정
# 복사: copy .env.example .env  —  `.env` 는 Git 에 올리지 마세요.

B2MARK_WATERMARK_SECRET_KEY=

# --- 온체인 / 컨트랙트 설정 ---
B2MARK_RPC_URL=
B2MARK_CONTRACT_ADDRESS=

# --- [필수] 관리자(서버) 통합 키 ---
# 역할: 컨트랙트 배포(Deployer), 소유자(Owner), 서명 권한(Signer)을 모두 가집니다.
# 주의: 반드시 Sepolia ETH(가스비)가 들어있는 지갑의 개인키를 입력하세요.
B2MARK_ADMIN_PRIVATE_KEY=

# --- [선택] 일반 사용자(Minter) 키 ---
# 역할: CLI에서 워터마크를 민팅할 때 가스비를 낼 사용자의 개인키입니다.
# 비워둘 경우 자동으로 위의 ADMIN 키를 사용하여 발급(결제)합니다.
B2MARK_USER_PRIVATE_KEY=

# --- API 업로드 한도 (선택) ---
# B2MARK_MAX_UPLOAD_BYTES=
# B2MARK_MAX_ROWS=
# B2MARK_MAX_COLS=
